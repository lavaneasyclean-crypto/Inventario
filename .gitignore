# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local

# vercel / netlify
.vercel
.netlify

# typescript
*.tsbuildinfo
next-env.d.ts

# legacy data (Access DB stays local as backup, never to repo)
/_legacy/

# ETL artifacts (CSVs generated from Access)
/scripts/etl/_out/
/scripts/etl/__pycache__/
/scripts/etl/.venv/

# OS
Thumbs.db
desktop.ini

# editor
.vscode/
.idea/
*.swp
